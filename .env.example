# CityAgent Analytics — environment template
# Copy to `.env`. NEVER commit a real .env (it is gitignored). Placeholders only.
#
# You can run with NO .env at all — every value below has a built-in default and
# `docker compose -f docker-compose.build.yaml up -d --build` works out of the box.
# On first boot the container auto-generates the encryption key, runs DB migrations,
# and (if set) seeds the admin. The OpenRouter LLM key is entered in the UI
# (Settings -> Models), NOT here.
#
# Realistic minimum to edit: nothing required. Set the admin + base URL below for
# a real deploy. Everything else is optional / has a sane default.

# ===================================================================
# COMMONLY SET (a real deploy usually sets these)
# ===================================================================

# Public URL the app is served on — MUST match your published port/domain.
# Drives links, CORS and embeds. Default works for local.
DASH_BASE_URL=http://localhost:3007

# First super-admin (optional). Set once on a fresh box to auto-create the owner
# on first boot. Idempotent (ignored if a user already exists). Skip these and the
# sign-in page shows a one-time "Create super-admin" form instead.
# DASH_ADMIN_EMAIL=admin@example.com
# DASH_ADMIN_PASSWORD=change-me-strong
# DASH_ADMIN_NAME=Admin

# ===================================================================
# AUTO — leave blank unless you have a reason
# ===================================================================

# LLM key: set from the UI (Settings -> Models), never here. The app seeds an
# editable OpenRouter provider; paste your key there (stored DB-only, encrypted).
# (This var is read only by offline eval/bench scripts, never the running app.)
# OPENROUTER_API_KEY=

# Fernet encryption key for stored LLM/SMTP secrets. LEAVE BLANK — it is
# auto-generated on first boot and persisted to the ca_uploads volume, stable
# across restarts/rebuilds. Set a fixed value ONLY for multi-host deploys or when
# restoring a DB dump from another box (its secrets were encrypted with that key).
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DASH_ENCRYPTION_KEY=

# ===================================================================
# PORTS / RUNTIME (change only if a default port is busy)
# ===================================================================
ENVIRONMENT=development                 # development | staging | production
APP_PORT=3007                           # host port -> app (container always listens on 3000)
POSTGRES_PORT=5439                      # host port -> postgres 5432
REDIS_PORT=6399                         # host port -> redis 6379
# HTTP_PORT=8001                        # only for nginx mode (docker-compose.nginx.yaml)

# ===================================================================
# CONFIGURED IN THE UI — NOT here
# ===================================================================
# - SSO / Google / Microsoft Entra / Okta / Keycloak / LDAP-AD:
#       Settings -> Identity Provider  (add providers, client id/secret, directories;
#       all stored in the DB, encrypted — no env vars or dash-config edits needed)
# - SMTP (invites & notifications):  Settings -> SMTP, or per-agent Email/SMTP tab
# - LLM (OpenRouter) key:            Settings -> Models
# - Feature flags:                   Settings -> Feature Flags (per-org)

# ===================================================================
# ADVANCED (rarely needed — all optional, sane defaults if unset)
# ===================================================================
# Database — default points at the bundled ca-postgres. Override for an external DB.
# DASH_DATABASE_URL=postgresql+asyncpg://dash:dashpassword@ca-postgres:5432/dash

# Enterprise license (gates EE features):
# DASH_LICENSE_KEY=

# Ops tuning:
# DASH_MAX_CONCURRENT_AGENTS=4  LLM_MAX_CONCURRENCY=8  DASH_SCHEDULER_DISABLED=false
