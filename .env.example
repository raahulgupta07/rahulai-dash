# CityAgent Analytics — environment template
# Copy to `.env` and fill in. NEVER commit a real .env (it is gitignored).
# Values here are placeholders only — no real secrets.
#
# The dash-config.yaml / configs/dash-config.dev.yaml files reference these via
# ${VAR} interpolation. The LLM API key is NOT set here — it is entered from the
# UI (Settings -> Models). New orgs are seeded with an editable OpenRouter
# provider (current models) whose key the user pastes in the UI.

# ------------------------------------------------------------------
# Core
# ------------------------------------------------------------------
ENVIRONMENT=development                 # development | staging | production
# Absolute path to the dash-config yaml (optional; defaults per environment)
# DASH_CONFIG_PATH=/app/dash-config.yaml
DASH_BASE_URL=http://localhost:3007     # public URL of the app

# ------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------
DASH_DATABASE_URL=postgresql+asyncpg://dash:dashpassword@ca-postgres:5432/dash
# Or component form (used when DASH_DATABASE_AUTH_PROVIDER != password):
# DASH_DATABASE_HOST=ca-postgres
# DASH_DATABASE_PORT=5432
# DASH_DATABASE_NAME=dash
# DASH_DATABASE_USER=dash
# DASH_DATABASE_PASSWORD=dashpassword
# DASH_DATABASE_AUTH_PROVIDER=password   # password | aws-iam
# DASH_DATABASE_AUTH_REGION=us-east-1
# DASH_DATABASE_SSL_MODE=prefer

# ------------------------------------------------------------------
# Encryption — REQUIRED
# Fernet key (urlsafe base64, 32 bytes). Encrypts org LLM/SMTP credentials in DB.
# Generate: python -c "import base64,secrets;print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# If unset in development, one is auto-generated (NOT safe for prod — credentials
# become undecryptable on restart). Set a stable key in any real deployment.
# ------------------------------------------------------------------
DASH_ENCRYPTION_KEY=

# ------------------------------------------------------------------
# First super-admin bootstrap (optional)
# Set once for a fresh deploy to auto-create the first owner/admin (the UI
# sign-up link was removed, so this is the supported bootstrap path).
# Idempotent — ignored if a user already exists. The first user auto-creates
# an org and becomes its owner; the seeder also marks it a global super-admin.
# ------------------------------------------------------------------
# DASH_ADMIN_EMAIL=admin@example.com
# DASH_ADMIN_PASSWORD=change-me-strong
# DASH_ADMIN_NAME=Admin

# ------------------------------------------------------------------
# LLM — the OpenRouter key is set from the UI (Settings -> Models), not here.
# This optional var is only read by offline eval/bench scripts, never the app.
# ------------------------------------------------------------------
# OPENROUTER_API_KEY=

# ------------------------------------------------------------------
# Auth (SSO) — all optional; enable the matching provider in dash-config.yaml
# ------------------------------------------------------------------
# Google OAuth
# DASH_GOOGLE_CLIENT_ID=
# DASH_GOOGLE_CLIENT_SECRET=
# Microsoft Entra (Azure AD)
# DASH_ENTRA_CLIENT_ID=
# DASH_ENTRA_CLIENT_SECRET=
# DASH_ENTRA_TENANT_ID=
# Okta OIDC
# DASH_OKTA_CLIENT_ID=
# DASH_OKTA_CLIENT_SECRET=
# LDAP / Active Directory (bind account password)
# DASH_LDAP_BIND_PASSWORD=

# ------------------------------------------------------------------
# Email / SMTP (optional — for invites & notifications)
# ------------------------------------------------------------------
# DASH_SMTP_USERNAME=
# DASH_SMTP_PASSWORD=

# ------------------------------------------------------------------
# Enterprise license (optional — gates EE features)
# ------------------------------------------------------------------
# DASH_LICENSE_KEY=

# ------------------------------------------------------------------
# Ops tuning (optional — sensible defaults if unset)
# ------------------------------------------------------------------
# DASH_MAX_CONCURRENT_AGENTS=4
# LLM_MAX_CONCURRENCY=8
# REDIS_URL=redis://localhost:6379/0
# DASH_SCHEDULER_DISABLED=false
